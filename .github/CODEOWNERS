# Image build inputs
Dockerfile                  @AndriyKalashnykov
Dockerfile.*                @AndriyKalashnykov
docker-compose.yml          @AndriyKalashnykov
compose.yaml                @AndriyKalashnykov
.dockerignore               @AndriyKalashnykov

# Release pipeline inputs
.goreleaser.yml             @AndriyKalashnykov
cosign.pub                  @AndriyKalashnykov
.cosign/**                  @AndriyKalashnykov

# Project conventions (anti-persistent-injection)
