{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticCommitType(chore)"
  ],
  "enabledManagers": [
    "gomod",
    "github-actions",
    "dockerfile",
    "mise",
    "npm",
    "custom.regex"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Makefile tool versions via inline renovate comments",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)(?: registryUrl=(?<registryUrl>[^\\s]+))?(?: versioning=(?<versioning>[^\\s]+))?\\n[A-Z_]+\\s*[?:]?=\\s*(?<currentValue>[^\\s]+)"
      ]
    }
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "commitMessagePrefix": "chore(all): ",
  "commitMessageAction": "update",
  "commitBody": "Signed-off-by: Renovate Bot <bot@renovateapp.com>",
  "labels": [
    "dependencies"
  ],
  "prConcurrentLimit": 50,
  "prHourlyLimit": 0,
  "platformAutomerge": true,
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "ignoreTests": false,
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ],
    "automerge": true,
    "minimumReleaseAge": "0 days"
  },
  "packageRules": [
    {
      "description": "Wait 3 days before automerging major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Group GitHub Actions into one PR",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions"
    },
    {
      "description": "Bump Go version in go.mod to latest patch",
      "matchManagers": [
        "gomod"
      ],
      "matchDepNames": [
        "go"
      ],
      "rangeStrategy": "bump"
    },
    {
      "description": "Group Docker base images",
      "matchDatasources": [
        "docker"
      ],
      "groupName": "Docker dependencies"
    },
    {
      "description": "Group Go module dependencies (excluding the Go toolchain itself, which has its own bump rule)",
      "matchManagers": [
        "gomod"
      ],
      "groupName": "Go dependencies",
      "excludeDepNames": [
        "go"
      ]
    },
    {
      "description": "Group toolchain pins (Makefile and .mise.toml inline-renovate-comment updates)",
      "matchManagers": [
        "custom.regex"
      ],
      "groupName": "Toolchain pins"
    },
    {
      "description": "Group Node.js dependencies",
      "matchManagers": [
        "npm"
      ],
      "groupName": "Node.js dependencies"
    },
    {
      "description": "govulncheck is an official Go sub-repo under golang/ with active main-branch commits and 0 open issues. Its CLI is intentionally stable; the CVE database at vuln.go.dev updates server-side independently of releases. Renovate's release-age abandonment heuristic produces a false positive here — set a 5-year threshold to silence it locally while still tracking version bumps. See CLAUDE.md Upgrade Backlog.",
      "matchDepNames": [
        "golang.org/x/vuln/cmd/govulncheck",
        "golang/vuln"
      ],
      "abandonmentThreshold": "5 years"
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["before 5am on monday"]
  },
  "npm": {
    "minimumReleaseAge": "3 days"
  }
}
