@startuml c4-container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.13.0/C4_Container.puml

' Landscape layout — keeps the single-container view from rendering as a tall portrait.
LAYOUT_LEFT_RIGHT()

' Modern flat styling: no shadows, sharper corners, clean sans-serif, modern palette.
skinparam backgroundColor #FAFAFA
skinparam shadowing false
skinparam roundCorner 4
skinparam defaultFontName "Inter, Helvetica, Arial, sans-serif"
skinparam defaultFontSize 13
skinparam ArrowColor #37474F
skinparam ArrowThickness 1.2
skinparam rectangleBorderThickness 1.3

UpdateElementStyle("person", $fontColor="#FFFFFF", $bgColor="#0F766E", $borderColor="#134E4A")
UpdateElementStyle("container", $fontColor="#FFFFFF", $bgColor="#2563EB", $borderColor="#1E3A8A")

title Container View — flight-path

Person(client, "API Client", "cURL, Postman, Newman, browser")

System_Boundary(api, "Flight Path API") {
  Container(server, "flight-path server", "Go 1.26.4, Echo v5.2.0", "Single static binary. Serves POST /calculate, GET /, and GET /swagger/* (embedded Swagger UI via swaggo/echo-swagger v2.0.1). Middleware: RequestID, Logger, Recover, BodyLimit 1 MiB, Gzip, RateLimiter (100/s, burst 200), CORS (multi-origin via CORS_ORIGIN), Secure headers, Cache-Control no-store. No datastore, broker, or cache.")
}

Rel(client, server, "POST /calculate, GET /, GET /swagger/*", "HTTPS / JSON")

SHOW_LEGEND()
@enduml
